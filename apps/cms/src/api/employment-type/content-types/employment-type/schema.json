{
  "kind": "collectionType",
  "collectionName": "employment_types",
  "info": {
    "singularName": "employment-type",
    "pluralName": "employment-types",
    "displayName": "Loại hình tuyển dụng / Employment Type"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "summary": { "type": "text" },
    "sortOrder": { "type": "integer", "default": 0 },
    "jobs": { "type": "relation", "relation": "oneToMany", "target": "api::career-job.career-job", "mappedBy": "employmentType" }
  }
}
