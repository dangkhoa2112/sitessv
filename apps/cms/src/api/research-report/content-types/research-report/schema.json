{
  "kind": "collectionType",
  "collectionName": "research_reports",
  "info": {
    "singularName": "research-report",
    "pluralName": "research-reports",
    "displayName": "Báo cáo phân tích / Research Report"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "summary": { "type": "text" },
    "content": { "type": "richtext" },
    "coverImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "reportType": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::research-report-type.research-report-type",
      "inversedBy": "reports"
    },
    "publishDate": { "type": "datetime" },
    "featured": { "type": "boolean", "default": false },
    "category": { "type": "relation", "relation": "manyToOne", "target": "api::research-category.research-category", "inversedBy": "reports" },
    "author": { "type": "relation", "relation": "manyToOne", "target": "api::author.author" },
    "tags": { "type": "relation", "relation": "manyToMany", "target": "api::tag.tag" },
    "documents": { "type": "relation", "relation": "manyToMany", "target": "api::downloadable-document.downloadable-document" },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo-meta" }
  }
}
