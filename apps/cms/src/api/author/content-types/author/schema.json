{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Tác giả / Author"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "title": { "type": "string" },
    "bio": { "type": "text" },
    "avatar": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "email": { "type": "email" },
    "linkedin": { "type": "string" }
  }
}
