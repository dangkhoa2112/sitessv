{
  "kind": "collectionType",
  "collectionName": "office_locations",
  "info": {
    "singularName": "office-location",
    "pluralName": "office-locations",
    "displayName": "Địa điểm văn phòng / Office Location"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "address": { "type": "text", "required": true },
    "city": { "type": "string" },
    "phone": { "type": "string" },
    "email": { "type": "email" },
    "officeType": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::office-type.office-type",
      "inversedBy": "offices"
    },
    "workingHours": { "type": "string" },
    "mapUrl": { "type": "string" },
    "sortOrder": { "type": "integer", "default": 0 },
    "featured": { "type": "boolean", "default": false }
  }
}
