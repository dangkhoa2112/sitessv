{
  "kind": "collectionType",
  "collectionName": "event_categories",
  "info": {
    "singularName": "event-category",
    "pluralName": "event-categories",
    "displayName": "Danh mục sự kiện / Event Category"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "summary": { "type": "text" },
    "events": { "type": "relation", "relation": "oneToMany", "target": "api::event.event", "mappedBy": "category" }
  }
}
