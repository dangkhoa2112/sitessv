{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Sự kiện / Event"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "summary": { "type": "text" },
    "content": { "type": "richtext" },
    "coverImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "publishDate": { "type": "datetime" },
    "startDate": { "type": "datetime" },
    "endDate": { "type": "datetime" },
    "location": { "type": "string" },
    "isOnline": { "type": "boolean", "default": false },
    "registrationUrl": { "type": "string" },
    "featured": { "type": "boolean", "default": false },
    "status": { "type": "enumeration", "enum": ["upcoming", "ongoing", "ended"], "default": "upcoming" },
    "category": { "type": "relation", "relation": "manyToOne", "target": "api::event-category.event-category", "inversedBy": "events" },
    "tags": { "type": "relation", "relation": "manyToMany", "target": "api::tag.tag" },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo-meta" }
  }
}
