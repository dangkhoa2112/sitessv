{
  "kind": "collectionType",
  "collectionName": "faq_items",
  "info": {
    "singularName": "faq-item",
    "pluralName": "faq-items",
    "displayName": "Câu hỏi thường gặp / FAQ Item"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "question": { "type": "string", "required": true },
    "slug": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "answer": { "type": "richtext", "required": true },
    "sortOrder": { "type": "integer", "default": 0 },
    "featured": { "type": "boolean", "default": false },
    "category": { "type": "relation", "relation": "manyToOne", "target": "api::faq-category.faq-category", "inversedBy": "items" },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo-meta" }
  }
}
